<plist version="1.0">
<dict>
	<key>NSHealthShareUsageDescription</key>
	<string>OpenVital reads your health data to provide it as a local REST API on this device. Your data never leaves this device.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSExceptionDomains</key>
		<dict>
			<key>localhost</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
			</dict>
		</dict>
	</dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>processing</string>
	</array>
</dict>
</plist>
